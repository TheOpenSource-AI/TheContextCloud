# Context Cloud - Environment Variables
# Copy to .env and fill in production values

# ── Go API Gateway ──────────────────────
PORT=8080
DATABASE_URL=postgres://cc_admin:cc_dev_password@localhost:5432/contextcloud?sslmode=disable
REDIS_URL=localhost:6379
JWT_SECRET=dev-secret-change-in-production

# ── MinIO (S3-Compatible Storage) ───────
MINIO_URL=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=context-cloud-uploads

# ── Kafka ───────────────────────────────
KAFKA_BROKER=localhost:9092

# ── Python AI Engine (gRPC) ─────────────
AI_ENGINE_URL=localhost:50051

# ── Next.js Frontend ────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
