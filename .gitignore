# ──────────────────────────────────────────
# Context Cloud — Full-Stack .gitignore
# ──────────────────────────────────────────

# ── Frontend (Next.js / Node) ──
node_modules/
/.next/
/out/
/build
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/coverage
*.tsbuildinfo
next-env.d.ts

# ── Go Backend ──
backend/bin/
backend/tmp/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/

# ── Python AI Engine ──
ai-engine/.venv/
ai-engine/__pycache__/
ai-engine/**/__pycache__/
ai-engine/*.pyc
ai-engine/.pytest_cache/
ai-engine/*.egg-info/
*.pyc
__pycache__/
.pytest_cache/

# ── Infrastructure ──
docker-compose.override.yml
*.log
postgres-data/
redis-data/
minio-data/
kafka-data/

# ── Environment Files ──
.env
.env.local
.env.*.local
!.env.example

# ── IDE & OS ──
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~
Thumbs.db

# ── Debug Logs ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Security ──
*.pem
*.key
*.cert
*.p12

# ── Vercel ──
.vercel

# ── Misc ──
*.bak
*.tmp
